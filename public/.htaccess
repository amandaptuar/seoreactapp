<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Forward all /api requests to the PHP proxy script
  RewriteRule ^api/(.*)$ /api.php?path=$1 [QSA,L]

  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
